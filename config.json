{
  "char_rules": [
    {
      "from_key": "2",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "@"
    },
    {
      "from_key": "3",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "£"
    },
    {
      "from_key": "4",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "$"
    },
    {
      "from_key": "5",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "€"
    },
    {
      "from_key": "7",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "{"
    },
    {
      "from_key": "8",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "["
    },
    {
      "from_key": "9",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "]"
    },
    {
      "from_key": "0",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "}"
    },
    {
      "from_key": "section",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "\\"
    },
    {
      "from_key": "equal",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "|"
    },
    {
      "from_key": "rightbracket",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "~"
    },
    {
      "from_key": "m",
      "from_mods": [
        "ralt"
      ],
      "global": true,
      "to_char": "µ"
    }
  ],
  "enabled": true,
  "excluded_apps": [
    "com.apple.Terminal",
    "com.googlecode.iterm2",
    "com.jetbrains.goland",
    "com.jetbrains.pycharm",
    "com.jetbrains.rider",
    "com.jetbrains.WebStorm",
    "com.jetbrains.datagrip",
    "com.jetbrains.clion",
    "com.jetbrains.rustrover",
    "com.microsoft.VSCode",
    "com.todesktop.230313mzl4w4u92",
    "com.jetbrains.intellij",
    "net.kovidgoyal.kitty"
  ],
  "key_rules": [
    {
      "from_key": "y",
      "from_mods": [
        "ctrl"
      ],
      "global": false,
      "to_key": "z",
      "to_mods": [
        "cmd",
        "shift"
      ]
    },
    {
      "from_mods": [
        "ctrl",
        "shift"
      ],
      "global": false,
      "keys": [
        "r",
        "t",
        "b"
      ],
      "to_mods": [
        "cmd",
        "shift"
      ]
    },
    {
      "from_mods": [
        "ctrl",
        "shift"
      ],
      "global": false,
      "keys": [
        "e",
        "c",
        "k"
      ],
      "to_mods": [
        "cmd",
        "alt"
      ]
    },
    {
      "from_mods": [
        "ctrl"
      ],
      "global": false,
      "keys": [
        "left",
        "right",
        "forwarddelete",
        "delete"
      ],
      "to_mods": [
        "alt"
      ]
    },
    {
      "from_mods": [
        "ctrl"
      ],
      "global": false,
      "keys": [
        "c",
        "v",
        "x",
        "a",
        "z",
        "s",
        "p",
        "f",
        "t",
        "w",
        "n",
        "d",
        "r",
        "return"
      ],
      "to_mods": [
        "cmd"
      ]
    }
  ],
  "mouse_rules": [
    {
      "button": "left",
      "from_mods": [
        "ctrl"
      ],
      "global": true,
      "to_mods": [
        "cmd"
      ]
    }
  ],
  "scroll_rules": [
    {
      "from_mods": [
        "ctrl"
      ],
      "global": false,
      "to_mods": [
        "cmd"
      ]
    }
  ]
}