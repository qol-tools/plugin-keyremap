{
  "enabled": true,
  "excluded_apps": [
    "net.kovidgoyal.kitty",
    "com.apple.Terminal",
    "com.googlecode.iterm2",
    "com.jetbrains.intellij",
    "com.jetbrains.goland",
    "com.jetbrains.pycharm",
    "com.jetbrains.rider",
    "com.jetbrains.WebStorm",
    "com.jetbrains.datagrip",
    "com.jetbrains.clion",
    "com.jetbrains.rustrover",
    "com.microsoft.VSCode",
    "com.todesktop.230313mzl4w4u92"
  ],
  "key_rules": [
    {
      "from_mods": ["ctrl"], "to_mods": ["cmd"],
      "keys": ["c", "v", "x", "a", "z", "s", "p", "f", "t", "w", "n", "d", "r", "return"]
    },
    {
      "from_mods": ["ctrl"], "to_mods": ["alt"],
      "keys": ["left", "right", "forwarddelete", "delete"]
    },
    {
      "from_mods": ["ctrl", "shift"], "to_mods": ["cmd", "shift"],
      "keys": ["r", "t", "b"]
    },
    {
      "from_mods": ["ctrl", "shift"], "to_mods": ["cmd", "alt"],
      "keys": ["e", "c", "k"]
    },
    { "from_mods": ["ctrl"], "from_key": "y", "to_mods": ["cmd", "shift"], "to_key": "z" }
  ],
  "mouse_rules": [
    { "from_mods": ["ctrl"], "button": "left", "to_mods": ["cmd"] }
  ],
  "scroll_rules": [
    { "from_mods": ["ctrl"], "to_mods": ["cmd"] }
  ]
}
